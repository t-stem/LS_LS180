-- SQL Querying Ex Set: Advanced 1 E-Commerce
SELECT orders.id, orders.created_at, customers.name FROM orders LEFT JOIN customers ON orders.customer_id = customers.id;

SELECT products.name, products.price FROM products INNER JOIN products_tags ON products.id = products_tags.product_id INNER JOIN tags on products_tags.tag_id = tags.id WHERE tags.name = 'tech' ORDER BY products.price ASC;

SELECT ROUND(AVG(distinct_count), 2) FROM (SELECT order_id, COUNT(product_id) AS distinct_count FROM orders_products GROUP BY order_id);

SELECT orders.created_at, products.name, orders_products.quantity FROM customers INNER JOIN orders ON customers.id = orders.customer_id INNER JOIN orders_products ON orders.id = orders_products.order_id INNER JOIN products ON orders_products.product_id = products.id WHERE customers.id = 1 ORDER BY orders.created_at DESC, products.name ASC;

SELECT products.name, COUNT(products_tags.tag_id) AS tag_count FROM products INNER JOIN products_tags ON products.id = products_tags.product_id GROUP BY products.name HAVING COUNT(products_tags.product_id) > 2;

SELECT DISTINCT orders.id FROM orders INNER JOIN orders_products ON orders.id = orders_products.order_id INNER JOIN products_tags ON orders_products.product_id = products_tags.product_id INNER JOIN tags on products_tags.tag_id = tags.id WHERE tags.name = 'audio';

SELECT orders.id AS order_id, customers.name AS customer_name, SUM(products.price * orders_products.quantity) AS total_price FROM orders INNER JOIN customers ON orders.customer_id = customers.id INNER JOIN orders_products ON orders.id = orders_products.order_id INNER JOIN products ON orders_products.product_id = products.id GROUP BY orders.id, customers.name;

SELECT customers.name, SUM(products.price * orders_products.quantity) AS spending FROM customers INNER JOIN orders on customers.id = orders.customer_id INNER JOIN orders_products ON orders.id = orders_products.order_id INNER JOIN products ON orders_products.product_id = products.id GROUP BY customers.id ORDER BY spending DESC;

SELECT tags.name AS tag, SUM(orders_products.quantity) AS products_ordered FROM tags LEFT JOIN products_tags ON tags.id = products_tags.tag_id LEFT JOIN orders_products ON products_tags.product_id = orders_products.product_id GROUP BY tags.id, tags.name ORDER BY products_ordered DESC;